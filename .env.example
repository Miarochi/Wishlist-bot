# Токен от @BotFather
BOT_TOKEN=123456:ABC-DEF

# Ваш telegram user id (узнать у @userinfobot). Только этот пользователь может управлять ботом.
OWNER_ID=123456789

# Часовой пояс для расписания напоминаний
TIMEZONE=Europe/Moscow

# Час дня (0-23), в который бот проверяет дни рождения и шлёт напоминания
REMINDER_HOUR=10

# За сколько дней до ДР присылать напоминание
REMINDER_DAYS_BEFORE=7

# Путь к файлу базы данных SQLite
DB_PATH=wishlist_bot.db
